<%- include("../../partials/backend/header.ejs") %>

<div class="admin-dashboard-container">

  <%- include("../../partials/backend/sidebar.ejs") %>

  <section class="dashboard-content">
    <div class="cms-header">
      <h4>About</h4>
      <div class="cms-sub-header">
        <p>Dashboard</p>
        <p>/</p>
        <p>Project</p>
      </div>

      <form action="/<%= adminLink %>/cms/new/project" method="POST" class="cms-form" enctype="multipart/form-data">
        <div class="instruction-hero">
          <h6>Update Project Section</h6>
          <a class="btn btn-primary" href="/<%= adminLink %>/cms/project"> back</a>
        </div>

        <div class="cms-input-area">
          <span>
            <label for="projectUrl">Project Url</label>
            <input type="text" placeholder="https://example.com" name="projectUrl" value="" required>
          </span>

          <span>
            <label for="projectName">Project Name</label>
            <input type="text" placeholder="Enter Project name" name="projectName" value="" required>
          </span>
          <span>
            <label class="cms-label" for="projectInformation">Project information</label>
            <textarea id="projectInformation" name="projectInformation" placeholder="Enter project information" required></textarea>
          </span>

          
          <span>
            <label for="stack-type">Project Stack</label>

            <input type="text" placeholder="Enter stack type" name="projectStack" value="" required>
          </span>

        <div class="about-image-upload">
          <span>
         <label for="imageUpload">Image Upload</label>
         <input type="file" id="projectImage" name="projectImage" accept="image/*" class="image-upload-input">
         </span>

         <span>

         <label for="altImage">Image Alt Text</label>
         <input type="text" id="altImage" name="projectAltText" placeholder="Enter image alt text" value="">
         </span>
         </div>

         <div class="uploaded-image-parent">
        
         </div>
        

          <button type="submit" class="cms-submit-btn">Save Changes</button>
        </div>
      
       <%- include("../../partials/backend/success-msg.ejs") %>
      </form>
    </div>

    
    <%- include("../../partials/backend/footer.ejs") %>
  </section>
</div>
